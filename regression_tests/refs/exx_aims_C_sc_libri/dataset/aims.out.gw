  Parsing control.in (first pass over file, find array dimensions only).
  The contents of control.in will be repeated verbatim below
  unless switched off by setting 'verbatim_writeout .false.' .
  in the first line of control.in .
  -----------------------------------------------------------------------
  
  #%FHI-aims
  
  # General setting
  xc               pbe
  relativistic     atomic_zora scalar
  occupation_type  gaussian 0.0001
  # basis_threshold  0.e-5
  
  # Use periodic GW
  qpe_calc         gw_expt
  
  # Set frequency grids.
  # For comparison with FHI-aims, we need the dielectric function from FHI-aims
  # So we need to have the same frequency grids in FHIaims and LibRPA
  frequency_points 6
  # Analytic continuation. We stick to Pade, and use all frequency points for fitting
  n_anacon_par 6
  anacon_type 1
  
  # Kgrids
  k_grid 1 1 1
  
  # Compute QPE for all states
  state_upper_limit 100000
  output k_eigenvalue 1
  output gw_regular_kgrid
  # restart_periodic_gw restart_pgw binary
  # periodic_gw_self_energy_restart rw
  # periodic_gw_optimize_kgrid_symmetry none
  # periodic_gw_use_average_inverse_dm_gamma .true.
  # periodic_gw_discard_wc_gamma .false.
  # periodic_gw_force_finite_size_correction .false.
  # periodic_gw_full_matrix .false.
  # output self_energy_matrix 512 32 .true.
  
  # ==========================================
  # Usually do not need to change things below
  # Dump datasets required by LibRPA
  # output librpa
  
  ################################################################################
  #
  #  FHI-aims code project
  #  VB, Fritz-Haber Institut, 2009
  #
  #  Suggested "light" defaults for C atom (to be pasted into control.in file)
  #  Be sure to double-check any results obtained with these settings for post-processing,
  #  e.g., with the "tight" defaults and larger basis sets.
  #
  ################################################################################
    species        C
  #     global species definitions
      nucleus             6
      mass                12.0107
  #
      l_hartree           4
  #
      cut_pot             3.5  1.5  1.0
      basis_dep_cutoff    1e-4
  #
      radial_base         34 5.0
      radial_multiplier   1
      angular_grids specified
        division   0.3326   50
        division   0.5710  110
        division   0.7727  194
        division   0.8772  302
  #      division   0.9334  434
  #      division   0.9625  590
  #      division   0.9924  770
  #      division   1.0230  974
  #      division   1.4589 1202
  #     outer_grid  974
       outer_grid 302
  ################################################################################
  #
  #  Definition of "minimal" basis
  #
  ################################################################################
  #     valence basis states
      valence      2  s   2.
      valence      2  p   2.
  #     ion occupancy
      ion_occ      2  s   1.
      ion_occ      2  p   1.
  ################################################################################
  #
  #  Suggested additional basis functions. For production calculations,
  #  uncomment them one after another (the most important basis functions are
  #  listed first).
  #
  #  Constructed for dimers: 1.0 A, 1.25 A, 1.5 A, 2.0 A, 3.0 A
  #
  ################################################################################
  #  "First tier" - improvements: -1214.57 meV to -155.61 meV
  #     hydro 2 p 1.7
  #     hydro 3 d 6
  #     hydro 2 s 4.9
  #  "Second tier" - improvements: -67.75 meV to -5.23 meV
  #     hydro 4 f 9.8
  #     hydro 3 p 5.2
  #     hydro 3 s 4.3
  #     hydro 5 g 14.4
  #     hydro 3 d 6.2
  #  "Third tier" - improvements: -2.43 meV to -0.60 meV
  #     hydro 2 p 5.6
  #     hydro 2 s 1.4
  #     hydro 3 d 4.9
  #     hydro 4 f 11.2
  #  "Fourth tier" - improvements: -0.39 meV to -0.18 meV
  #     hydro 2 p 2.1
  #     hydro 5 g 16.4
  #     hydro 4 d 13.2
  #     hydro 3 s 13.6
  #     hydro 4 f 17.6
  #  Further basis functions - improvements: -0.08 meV and below
  #     hydro 3 s 2
  #     hydro 3 p 6
  #     hydro 4 d 20
  
